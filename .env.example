# Get a free OpenRouter key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Default to a free model — works with $0 OpenRouter balance. 131K context, strong instruction-following.
# Swap to anthropic/claude-sonnet-4 or anthropic/claude-haiku-4.5 once you've added credits for production-grade output.
OPENROUTER_MODEL=openai/gpt-oss-120b:free

FLASK_ENV=development
